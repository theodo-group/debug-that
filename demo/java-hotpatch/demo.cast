[0.000, "o", "   \u001b[90m 1\u001b[0m│\u001b[34mpackage\u001b[0m com.example;\r\n   \u001b[90m 2\u001b[0m│\r\n   \u001b[90m 3\u001b[0m│\u001b[34mimport\u001b[0m org.springframework.web.bind.annotation.\u001b[36mGetMapping\u001b[0m;\r\n   \u001b[90m 4\u001b[0m│\u001b[34mimport\u001b[0m org.springframework.web.bind.annotation.\u001b[36mRequestParam\u001b[0m;\r\n   \u001b[90m 5\u001b[0m│\u001b[34mimport\u001b[0m org.springframework.web.bind.annotation.\u001b[36mRestController\u001b[0m;\r\n   \u001b[90m 6\u001b[0m│\u001b[34mimport\u001b[0m java.util.\u001b[36mMap\u001b[0m;\r\n   \u001b[90m 7\u001b[0m│\r\n   \u001b[90m 8\u001b[0m│@\u001b[36mRestController\u001b[0m\r\n   \u001b[90m 9\u001b[0m│\u001b[34mpublic\u001b[0m \u001b[34mclass\u001b[0m \u001b[36mPricingController\u001b[0m {\r\n   \u001b[90m10\u001b[0m│\r\n   \u001b[90m11\u001b[0m│    \u001b[34mprivate\u001b[0m \u001b[34mstatic\u001b[0m \u001b[34mfinal\u001b[0m \u001b[34mdouble\u001b[0m \u001b[36mVAT_RATE\u001b[0m = \u001b[33m0.20\u001b[0m;\r\n   \u001b[90m12\u001b[0m│\r\n   \u001b[90m13\u001b[0m│    @\u001b[36mGetMapping\u001b[0m(\u001b[32m\"/price\"\u001b[0m)\r\n   \u001b[90m14\u001b[0m│    \u001b[34mpublic\u001b[0m \u001b[36mMap\u001b[0m<\u001b[36mString\u001b[0m, \u001b[36mObject\u001b[0m> getPrice(\r\n   \u001b[90m15\u001b[0m│            @\u001b[36mRequestParam\u001b[0m(defaultValue = \u001b[32m\"49.99\"\u001b[0m) \u001b[34mdouble\u001b[0m price,\r\n   \u001b[90m16\u001b[0m│            @\u001b[36mRequestP"]
[0.000, "o", "aram\u001b[0m(defaultValue = \u001b[32m\"3\"\u001b[0m) \u001b[34mint\u001b[0m qty,\r\n   \u001b[90m17\u001b[0m│            @\u001b[36mRequestParam\u001b[0m(defaultValue = \u001b[32m\"20\"\u001b[0m) \u001b[34mdouble\u001b[0m discount) {\r\n   \u001b[90m18\u001b[0m│\r\n   \u001b[90m19\u001b[0m│        \u001b[34mdouble\u001b[0m subtotal = price * qty;\r\n   \u001b[90m20\u001b[0m│        \u001b[90m// BUG: VAT applied to discount instead of net amount\u001b[0m\r\n\u001b[93m →\u001b[0m \u001b[90m21\u001b[0m│        \u001b[34mdouble\u001b[0m total = subtotal - discount + (discount * \u001b[36mVAT_RATE\u001b[0m);\r\n   \u001b[90m22\u001b[0m│        total = \u001b[36mMath\u001b[0m.round(total * \u001b[33m100.0\u001b[0m) / \u001b[33m100.0\u001b[0m;\r\n   \u001b[90m23\u001b[0m│\r\n   \u001b[90m24\u001b[0m│        \u001b[34mreturn\u001b[0m \u001b[36mMap\u001b[0m.of(\r\n   \u001b[90m25\u001b[0m│            \u001b[32m\"subtotal\"\u001b[0m, subtotal,\r\n   \u001b[90m26\u001b[0m│            \u001b[32m\"discount\"\u001b[0m, discount,\r\n   \u001b[90m27\u001b[0m│            \u001b[32m\"vat_rate\"\u001b[0m, \u001b[36mVAT_RATE\u001b[0m,\r\n   \u001b[90m28\u001b[0m│            \u001b[32m\"total\"\u001b[0m, total\r\n   \u001b[90m29\u001b[0m│        );\r\n   \u001b[90m30\u001b[0m│    }\r\n   \u001b[90m31\u001b[0m│}\r\n   \u001b[90m32\u001b[0m│\r\n"]
